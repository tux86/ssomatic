{
  "name": "@awsume/gui",
  "version": "1.0.0",
  "description": "Electron desktop app for Awsume",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "tux86",
    "email": "tux86@users.noreply.github.com"
  },
  "homepage": "https://github.com/tux86/awsume",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run build:electron && concurrently \"bun run dev:vite\" \"bun run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "sleep 2 && electron dist-electron/main.js",
    "build:electron": "bun run scripts/build-electron.ts",
    "build": "bun run build:electron && vite build && electron-builder --config electron-builder.yml",
    "preview": "vite preview"
  },
  "dependencies": {
    "@awsume/core": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
